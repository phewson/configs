defaults
auth xoauth2
tls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile ~/.msmtp.log

account gmail
host smtp.gmail.com
port 587
from texhewson@gmail.com
user texhewson@gmail.com
passwordeval "~/configs/scripts/get-gmail-refresh-token.sh"
tls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
account default : gmail
